{
  "name": "lkd-web-kit",
  "version": "0.10.3",
  "description": "A template for creating React component libraries with Vite.",
  "author": "LKD",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jrjais/lkd-web-kit"
  },
  "type": "module",
  "main": "./dist/index.cjs",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "require": "./dist/index.cjs",
      "import": "./dist/index.js"
    }
  },
  "bin": {
    "lkd-install-agent-skills": "./scripts/install-agent-skills.mjs"
  },
  "sideEffects": false,
  "engines": {
    "node": ">=22.12.0"
  },
  "files": ["dist", ".agents/skills", "scripts/install-agent-skills.mjs"],
  "scripts": {
    "test": "vitest run --passWithNoTests",
    "test:watch": "vitest",
    "build": "tsc && vite build",
    "lint": "biome check",
    "format": "biome format --write",
    "prepublishOnly": "npm run build"
  },
  "devDependencies": {
    "@biomejs/biome": "2.4.14",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.13.24",
    "@testing-library/jest-dom": "^6.8.0",
    "@testing-library/react": "^16.3.0",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^22.17.2",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react-swc": "^4.3.0",
    "@vitest/coverage-v8": "^4.1.5",
    "jsdom": "^26.1.0",
    "rollup": "^4.53.3",
    "rollup-preserve-directives": "^1.1.3",
    "typescript": "^5.9.2",
    "vite": "^8.0.10",
    "vite-plugin-dts": "^5.0.0",
    "vitest": "^4.1.5"
  },
  "peerDependencies": {
    "@mantine/core": "^9.4.1",
    "@mantine/dates": "^9.4.1",
    "@mantine/hooks": "^9.4.1",
    "@mantine/notifications": "^9.4.1",
    "@tanstack/react-query": "^5.101.2",
    "@tanstack/react-table": "^8.21.3",
    "@tanstack/react-virtual": "^3.14.4",
    "clsx": "^2.1.1",
    "ky": "^2.0.2",
    "next": "^16.2.9",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-hook-form": "^7.80.0",
    "react-query-kit": "^3.3.4",
    "zod": "^4.4.3"
  },
  "dependencies": {}
}
